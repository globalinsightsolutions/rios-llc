{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/terms-of-service.html",
      "destination": "/legal/terms-of-service.html",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/legal/privacy-policy.html",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about.html",
      "permanent": true
    },
    {
      "source": "/a2p-opt-in-proof",
      "destination": "/a2p-opt-in-proof.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
